# ==========================================
# 1. 基础环境：保持不变，使用国内源的轻量版 Python
# ==========================================
FROM swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/library/python:3.10-slim

# ==========================================
# 2. 容器内部置目录
# ==========================================
WORKDIR /app

# ==========================================
# 3. 复制依赖清单并安装
# ==========================================
COPY requirements.txt .
# 提示：请确保你的 requirements.txt 里包含了 pytest、pytest-html 
# 以及脚本所需的 requests 等库。这里额外加上了清华源加速安装。
RUN pip install --no-cache-dir -i https://pypi.tuna.tsinghua.edu.cn/simple -r requirements.txt

# ==========================================
# 4. 把当前所有测试代码、配置和数据复制到容器里
# ==========================================
COPY . .

# ==========================================
# 5. 【新增】提前创建好存放测试报告的文件夹
# ==========================================
RUN mkdir -p /app/reports

# ==========================================
# 6. 【关键修改】设置默认运行命令为执行 pytest
# ==========================================
# 容器启动时会自动跑 pytest，并将生成的 HTML 报告统一输出到 /app/reports/ 目录下
CMD ["pytest", "-v", "--html=reports/report.html", "--self-contained-html"]