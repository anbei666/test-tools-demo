# ==========================================
# 1. 基础环境：保持不变，使用轻量版 Python
# ==========================================
# FROM python:3.10-slim
# 彻底放弃带有 /library/python 的官方路径，改用国内直接可拉取的第三方镜像站路径
FROM swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/library/python:3.10-slim

# ==========================================
# 2. 容器内部署目录：保持不变
# ==========================================
WORKDIR /app

# ==========================================
# 3. 复制依赖清单并安装
# ==========================================
COPY requirements.txt .
# ✅ 提示：请确保你的 requirements.txt 里不仅有 pytest，
#    还包含了运行 Web 服务所需的包（如 flask, fastapi, uvicorn 等）
RUN pip install --no-cache-dir -r requirements.txt

# ==========================================
# 4. 把当前所有代码复制到容器里
# ==========================================
COPY . .

# ==========================================
# 5. 【新增】声明容器内程序监听的端口
# ==========================================
# 🌟 这只是一个声明（文档作用），并不强制限制。
#    建议设置为你的 Python 程序实际监听的端口（例如 8000）
EXPOSE 8000

# ==========================================
# 6. 【关键修改】设置默认运行主程序（Web 服务）
# ==========================================
# 🚨 请根据你的主程序文件名进行修改！
#    假设你的主程序文件叫 `app.py`，且内部启动了 Web 服务（如 app.run()）

# ✅ [方式一：最通用的 Python 启动方式] 
CMD ["python", "app.py"]

# ------------------------------------------
# ⭐ [方式二：如果你的程序是 Flask] (推荐)
# 需要在 app.py 之外设置环境变量
# ENV FLASK_APP=app.py
# CMD ["flask", "run", "--host=0.0.0.0", "--port=8000"]

# ------------------------------------------
# ⭐ [方式三：如果你的程序是 FastAPI/Uvicorn]
# CMD ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "8000"]
# ==========================================